# Target Platform
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq53xx=y
CONFIG_TARGET_qualcommax_ipq53xx_DEVICE_zyxel_nwa130be=y

# LuCI (Web Interface)
CONFIG_LUCI=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_LUCI_THEME_argon=y

# Basic System
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-system=y
CONFIG_PACKAGE_luci-app-network=y

# WiFi & Hardware
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_ath11k-firmware-qca5398=y
CONFIG_PACKAGE_kmod-leds-gpio=y
# This is an empty file, please overwrite it after generating the .config file with the source code
